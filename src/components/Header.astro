---
import ThemeToggle from './svelte/ThemeToggle.svelte';

interface Props {
  currentPath?: string;
}

const { currentPath = '' } = Astro.props;

const navItems = [
  {
    href: '/blog',
    label: 'Blog',
    match: '/blog',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 19.5v-15A2.5 2.5 0 0 1 6.5 2H20v20H6.5a2.5 2.5 0 0 1 0-5H20"/></svg>`,
  },
  {
    href: '/series/project-euler',
    label: 'Project Euler',
    match: '/series/project-euler',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M8 3H5a2 2 0 0 0-2 2v3"/><path d="M21 8V5a2 2 0 0 0-2-2h-3"/><path d="M3 16v3a2 2 0 0 0 2 2h3"/><path d="M16 21h3a2 2 0 0 0 2-2v-3"/><path d="m10 14 2-2 2 2 2-2"/><path d="M10 10h4"/></svg>`,
  },
  {
    href: '/guide',
    label: 'Guide',
    match: '/guide',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg>`,
  },
  {
    href: '/about',
    label: 'About',
    match: '/about',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="8" r="5"/><path d="M20 21a8 8 0 0 0-16 0"/></svg>`,
  },
];
---

<header class="border-b border-border bg-background">
  <div class="max-w-5xl mx-auto px-6 py-5 md:py-6">
    <nav class="flex items-center justify-between">
      <a
        href="/"
        class="text-xl md:text-2xl font-serif tracking-tight text-foreground hover:text-accent transition-colors"
      >
        Wireframe
      </a>

      <div class="hidden md:flex items-center gap-6">
        {navItems.map(item => (
          <a
            href={item.href}
            class:list={[
              "flex items-center gap-1.5 text-sm transition-colors",
              currentPath.includes(item.match)
                ? "text-foreground font-medium"
                : "text-muted-foreground hover:text-foreground"
            ]}
          >
            <span class="opacity-60" set:html={item.icon} />
            {item.label}
          </a>
        ))}

        <div class="ml-2">
          <ThemeToggle client:load />
        </div>
      </div>

      <!-- Mobile: theme toggle + hamburger placeholder -->
      <div class="flex items-center gap-2 md:hidden">
        <ThemeToggle client:load />
        <button
          class="p-2 -mr-2 text-muted-foreground hover:text-foreground transition-colors"
          aria-label="메뉴 열기"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="4" x2="20" y1="12" y2="12"/><line x1="4" x2="20" y1="6" y2="6"/><line x1="4" x2="20" y1="18" y2="18"/></svg>
        </button>
      </div>
    </nav>
  </div>
</header>
