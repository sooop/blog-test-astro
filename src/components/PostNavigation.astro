---
interface Props {
  prevPost?: {
    url: string;
    title: string;
  } | null;
  nextPost?: {
    url: string;
    title: string;
  } | null;
  listUrl: string;
  listLabel?: string;
}

const { prevPost, nextPost, listUrl, listLabel = '목록' } = Astro.props;
---

<nav class="mt-16 pt-8 border-t border-border">
  <div class="grid grid-cols-3 gap-4 items-start">
    <div class="col-span-1">
      {prevPost && (
        <a href={prevPost.url} class="group flex items-start gap-2">
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="16"
            height="16"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            class="mt-0.5 shrink-0 text-muted-foreground group-hover:text-accent transition-colors"
          >
            <path d="m15 18-6-6 6-6"/>
          </svg>
          <span class="block">
            <span class="text-xs text-muted-foreground uppercase tracking-wider">이전 글</span>
            <span class="block font-serif text-base mt-0.5 group-hover:text-accent transition-colors line-clamp-2">
              {prevPost.title}
            </span>
          </span>
        </a>
      )}
    </div>

    <div class="col-span-1 flex justify-center">
      <a
        href={listUrl}
        class="inline-flex items-center gap-1.5 text-sm text-muted-foreground hover:text-foreground transition-colors px-4 py-2 border border-border hover:border-foreground whitespace-nowrap"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <line x1="8" x2="21" y1="6" y2="6"/>
          <line x1="8" x2="21" y1="12" y2="12"/>
          <line x1="8" x2="21" y1="18" y2="18"/>
          <line x1="3" x2="3.01" y1="6" y2="6"/>
          <line x1="3" x2="3.01" y1="12" y2="12"/>
          <line x1="3" x2="3.01" y1="18" y2="18"/>
        </svg>
        {listLabel}
      </a>
    </div>

    <div class="col-span-1 text-right">
      {nextPost && (
        <a href={nextPost.url} class="group inline-flex items-start gap-2 justify-end">
          <span class="block">
            <span class="text-xs text-muted-foreground uppercase tracking-wider">다음 글</span>
            <span class="block font-serif text-base mt-0.5 group-hover:text-accent transition-colors line-clamp-2">
              {nextPost.title}
            </span>
          </span>
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="16"
            height="16"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            class="mt-0.5 shrink-0 text-muted-foreground group-hover:text-accent transition-colors"
          >
            <path d="m9 18 6-6-6-6"/>
          </svg>
        </a>
      )}
    </div>
  </div>
</nav>
