---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import DraftSidebar from '../../components/svelte/DraftSidebar.svelte';

export async function getStaticPaths() {
  if (import.meta.env.PROD) return [];

  const entries = await getCollection('draft');
  const sorted = entries.sort((a, b) =>
    new Date(b.data.published_date).getTime() - new Date(a.data.published_date).getTime()
  );
  const drafts = sorted.map((e) => ({ title: e.data.title, slug: e.data.slug }));

  return entries.map((entry) => ({
    params: { slug: entry.data.slug },
    props: { entry, drafts },
  }));
}

const { entry, drafts } = Astro.props;

if (import.meta.env.PROD) {
  return Astro.redirect('/404');
}

const { Content } = await render(entry);
---

<BaseLayout title={entry.data.title} description={entry.data.custom_excerpt} currentPath="/draft">
  <div class="flex h-[calc(100vh-4rem)] overflow-hidden">
    <!-- Sidebar -->
    <div class="w-56 shrink-0 flex flex-col overflow-hidden border-r border-border">
      <div class="px-3 pt-3 pb-2 border-b border-border">
        <p class="text-xs font-mono uppercase tracking-widest text-muted-foreground">Draft</p>
      </div>
      <DraftSidebar client:load {drafts} currentSlug={entry.data.slug} />
    </div>

    <!-- Content -->
    <div class="flex-1 overflow-y-auto">
      <article class="max-w-3xl mx-auto px-6 py-10">
        <header class="mb-10">
          <div class="mb-3">
            <span class="inline-flex items-center gap-1.5 text-xs font-medium text-amber-600 dark:text-amber-400 border border-amber-300 dark:border-amber-700 px-2 py-0.5">
              DRAFT
            </span>
          </div>
          <h1 class="font-serif text-3xl md:text-4xl mb-4 text-foreground leading-tight">
            {entry.data.title}
          </h1>
          {entry.data.custom_excerpt && (
            <p class="text-lg text-muted-foreground leading-relaxed font-serif">
              {entry.data.custom_excerpt}
            </p>
          )}
        </header>

        <div class="prose prose-lg max-w-none">
          <Content />
        </div>
      </article>
    </div>
  </div>
</BaseLayout>
